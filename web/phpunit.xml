<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Modules">
            <directory>Modules/Admin/tests</directory>
            <directory>Modules/Api/tests</directory>
            <directory>Modules/Logging/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>Modules/Admin/app/Models/</directory>
            <directory>Modules/Admin/app/Services/</directory>
            <directory>Modules/Api/app/Models/</directory>
            <directory>Modules/Api/app/GraphQL/Resolvers/</directory>
            <directory>Modules/Api/app/Utils/</directory>
            <directory>Modules/Logging/app/Utils/</directory>
        </include>
        <exclude>
            <directory>app/Datatables</directory>
            <directory>app/Console/Commands</directory>
            <file>app/Http/Controllers/BaseController.php</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="MEMORY_LIMIT" value="512M"/>
    </php>
    <coverage>
        <report>
            <text outputFile="storage/test-coverage/coverage.txt" showUncoveredFiles="true" />
            <html outputDirectory="storage/test-coverage"/>
        </report>
    </coverage>
    <logging>
        <junit outputFile="storage/test-results/junit.xml"/>
        <testdoxText outputFile="storage/test-results/testdox.txt"/>
    </logging>
</phpunit>
